{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/[module]",
      "regex": "^/api/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmodule": "nxtPmodule"
      },
      "namedRegex": "^/api/(?<nxtPmodule>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/[module]",
      "regex": "^/dashboard/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmodule": "nxtPmodule"
      },
      "namedRegex": "^/dashboard/(?<nxtPmodule>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portal/policies/[id]",
      "regex": "^/portal/policies/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/portal/policies/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
